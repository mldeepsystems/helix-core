#!/usr/bin/env bash
# helix — CLI entrypoint for helix-core
#
# Zero-friction: just type `helix` to auto-setup, start, and launch Claude Code.
#
# Install globally:
#   sudo ln -sf "$(cd "$(dirname "$0")" && pwd)/helix" /usr/local/bin/helix
#
# Usage:
#   helix                             Auto-setup + start + launch Claude Code
#   helix up [--timeout N]            Start stack only (no Claude launch)
#   helix down                        Stop all containers
#   helix status                      Show service health
#   helix setup [options]             Interactive setup (hardware, model, .env)
#   helix check                       Smoke test the running stack
#   helix cloud init                  Provision a cloud GPU (deferred to v1.1)
#   helix help                        Show this help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

_usage() {
  cat <<EOF
helix — helix-core CLI

Usage:
  helix                         Auto-setup + start + launch Claude Code
  helix up [--timeout N]        Start stack (without launching Claude)
  helix down                    Stop all containers
  helix status                  Show service health
  helix setup [options]         Interactive setup (hardware, model, .env)
  helix check                   Smoke test the running stack
  helix cloud init              Provision a cloud GPU (deferred)
  helix help                    Show this help

Setup options:
  --model KEY              Skip interactive model selection (e.g. qwen2.5-coder-32b)
  --mode  MODE             Skip interactive mode selection (local|cpu|cloud)
  --skip-download          Configure only, do not download model

Examples:
  helix                                    # just works
  helix setup --model qwen2.5-coder-7b    # interactive setup with specific model
  helix up --timeout 300                   # start stack with longer timeout
  helix down                               # stop everything
EOF
}

_require_python() {
  if ! command -v python3 &>/dev/null; then
    echo "error: python3 not found — install Python 3.10+" >&2
    exit 1
  fi
}

# ── Compose helper (respects platform) ──────────────────────────────────────

_compose_cmd() {
  local mode
  mode="$(grep -E '^DEPLOYMENT_MODE=' "${REPO_ROOT}/.env" 2>/dev/null | cut -d= -f2 || echo "local")"

  if [[ "$(uname -s)" == "Darwin" && "$(uname -m)" == "arm64" ]]; then
    echo "docker compose -f docker-compose.mac.yml"
  elif [[ "$mode" == "cpu" ]]; then
    echo "docker compose -f docker-compose.yml -f docker-compose.cpu.yml"
  else
    echo "docker compose -f docker-compose.yml"
  fi
}

CMD="${1:-}"
shift || true

case "$CMD" in
  "")
    # Default: zero-friction auto-start + launch claude
    _require_python
    exec python3 "${SCRIPT_DIR}/start.py" "$@"
    ;;
  up)
    # Start stack without launching claude
    _require_python
    exec python3 "${SCRIPT_DIR}/start.py" --no-launch "$@"
    ;;
  down)
    cd "${REPO_ROOT}"
    COMPOSE_CMD=$(_compose_cmd)
    echo "Stopping helix-core stack..."
    ${COMPOSE_CMD} down "$@"
    echo "Stack stopped."
    ;;
  status)
    _require_python
    exec python3 "${SCRIPT_DIR}/check.py" "$@"
    ;;
  setup)
    _require_python
    exec python3 "${SCRIPT_DIR}/setup.py" "$@"
    ;;
  check)
    _require_python
    exec python3 "${SCRIPT_DIR}/check.py" "$@"
    ;;
  cloud)
    SUBCMD="${1:-}"
    if [[ "$SUBCMD" == "init" ]]; then
      echo ""
      echo "helix cloud init — deferred to v1.1"
      echo ""
      echo "Cloud GPU provisioning (GCP + RunPod) ships in a follow-on release."
      echo "The local stack (Modes 1–3) must be validated first."
      echo ""
      echo "In the meantime, you can manually provision a GPU VM and point"
      echo "ANTHROPIC_BASE_URL at its public IP:4000."
      echo ""
      exit 0
    else
      echo "error: unknown cloud subcommand: '${SUBCMD}'" >&2
      echo "Available: helix cloud init" >&2
      exit 1
    fi
    ;;
  help|--help|-h)
    _usage
    ;;
  *)
    echo "error: unknown command: '$CMD'" >&2
    echo ""
    _usage >&2
    exit 1
    ;;
esac
