# helix-core configuration
# Run `python scripts/setup.py` to populate this file automatically.
# Manual setup: copy to .env and fill in the values below.

# ── Model ────────────────────────────────────────────────────────────────────
MODEL_PATH=                        # absolute path to your GGUF file
MODEL_KEY=                         # model key, e.g. qwen2.5-coder-32b
CONTEXT_LENGTH=32768
DEPLOYMENT_MODE=local              # local | cpu | cloud

# ── LiteLLM proxy (Anthropic → OpenAI translation) ───────────────────────────
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-helix-local  # must match ANTHROPIC_AUTH_TOKEN below

# ── llama-server ─────────────────────────────────────────────────────────────
LLAMA_SERVER_PORT=8080
# Number of layers to offload to GPU (99 = all layers; 0 = CPU only)
N_GPU_LAYERS=99
# Tool call parser — must match model family:
#   Qwen:     qwen2_5
#   DeepSeek: deepseek
#   Llama:    llama3_json
TOOL_CALL_PARSER=qwen2_5

# ── Claude Code (set these in your shell after running setup) ─────────────────
# export ANTHROPIC_BASE_URL=http://localhost:${LITELLM_PORT}
# export ANTHROPIC_AUTH_TOKEN=${LITELLM_MASTER_KEY}

# ── Langfuse v2 (self-hosted) ─────────────────────────────────────────────────
# Generated by setup.py via `openssl rand`. DO NOT change after first boot.
# Changing these invalidates all sessions and API key hashes.
LANGFUSE_PORT=3002
LANGFUSE_NEXTAUTH_SECRET=          # openssl rand -base64 32
LANGFUSE_SALT=                     # openssl rand -base64 32
LANGFUSE_ENCRYPTION_KEY=           # openssl rand -hex 32  (must be 64 hex chars)

# Headless init — project API keys (you choose the values, Langfuse stores them)
LANGFUSE_INIT_USER_EMAIL=admin@helix.local
LANGFUSE_INIT_USER_PASSWORD=       # choose a strong password
LANGFUSE_INIT_PROJECT_NAME=helix-core
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=  # e.g. pk-helix-local-1234
LANGFUSE_INIT_PROJECT_SECRET_KEY=  # e.g. sk-lf-helix-local-1234

# ── Langfuse database ─────────────────────────────────────────────────────────
LANGFUSE_DB_PASSWORD=langfuse-local  # change for any internet-exposed deployment

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=helix-local   # Grafana UI password (admin user)

# ── AgentDx bridge ────────────────────────────────────────────────────────────
AGENTDX_ENABLED=true
AGENTDX_POLL_INTERVAL=30           # seconds between Langfuse polls
